# SPARK frontend (Vite) — never commit real secrets
# Docs: README backend setup + Notion Developer Layer

# Supabase (SPARK project only — not ELOGISO)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_USE_SUPABASE=false
VITE_REQUIRE_AUTH=false

# Optional: allow explicit offline provider simulation for demos
# When false (default), missing API keys surface as failures with clear errors
VITE_ALLOW_PROVIDER_SIMULATION=true

# Server-only (Vercel Environment Variables — never VITE_ prefix)
# OPEN_AI_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=
# XAI_API_KEY=
# FLUX_API_KEY=
# FAL_API_KEY=
# IDEOGRAM_API_KEY=
